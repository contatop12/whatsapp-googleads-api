# =============================================================================
# WhatsApp → Google Ads — variáveis de ambiente
# =============================================================================
# Copie este arquivo para `.env` na raiz do projeto (ou em `backend/.env` ao
# rodar o FastAPI) e preencha os valores reais.
#
# Referência: PRD-rastreamento-whatsapp-google-ads.md
# Backend lê as variáveis via backend/app/config.py (Pydantic Settings).
# =============================================================================


# -----------------------------------------------------------------------------
# Aplicação (Backend FastAPI)
# -----------------------------------------------------------------------------
# Ambiente: development | staging | production
ENVIRONMENT=development

# URL pública do backend (webhooks Evolution, snippet /api/track no site)
BACKEND_URL=http://localhost:8000

# CORS fixo: dashboard e URLs que não vêm do banco (separadas por vírgula).
# Sites do cliente (snippet /api/track) são cadastrados em Configurações → Sites permitidos.
ALLOWED_ORIGINS=http://localhost:3000

# Chave secreta da aplicação (JWT interno, sessões — use valor forte em produção)
SECRET_KEY=change-me-use-openssl-rand-hex-32


# -----------------------------------------------------------------------------
# Supabase — banco, Auth e RLS (PRD §2, §4, §8)
# -----------------------------------------------------------------------------
# Projeto → Settings → API
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# anon / public — usado pelo backend quando necessário e pelo frontend (Auth)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# service_role — APENAS no backend; ignora RLS; nunca exponha no browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret — validação do Bearer token (dashboard → API protegida)
# Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=


# -----------------------------------------------------------------------------
# Frontend Next.js (quando o dashboard existir — PRD §10)
# -----------------------------------------------------------------------------
# Mesmos valores do Supabase, prefixo NEXT_PUBLIC_ para o cliente React
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL pública do backend para chamadas do dashboard e do snippet no site
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000


# -----------------------------------------------------------------------------
# Google Ads — Offline Conversion API (PRD §6)
# -----------------------------------------------------------------------------
# Google Ads API Center → Developer token
GOOGLE_ADS_DEVELOPER_TOKEN=

# Google Cloud Console → OAuth 2.0 (tipo Desktop ou Web)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Refresh token OAuth após autorizar a conta MCC/cliente
GOOGLE_ADS_REFRESH_TOKEN=

# ID da conta MCC (opcional — referência; customer_id por tenant fica na tabela `tenants`)
GOOGLE_ADS_MCC_ID=

# Nota: customer_id e nomes das conversões ficam por tenant na tabela `tenants`,
# não neste .env global.


# -----------------------------------------------------------------------------
# Evolution API — WhatsApp webhooks (PRD §7)
# -----------------------------------------------------------------------------
# URL base da sua instância Evolution (ex.: https://evolution.seudominio.com)
EVOLUTION_API_BASE_URL=https://sua-evolution-api.com

# API key global (header apikey) para criar instâncias e configurar webhooks
EVOLUTION_API_GLOBAL_KEY=

# Webhook configurado automaticamente pelo backend:
#   POST {BACKEND_URL}/webhooks/evolution/{tenant_slug}


# -----------------------------------------------------------------------------
# Geolocalização por IP (PRD §6.2 — POST /api/track)
# -----------------------------------------------------------------------------
# Opcional. O serviço atual usa ip-api.com (grátis, sem chave).
# Reservado para provedor pago (ex.: ipapi.co) se configurado no futuro.
IPAPI_KEY=


# -----------------------------------------------------------------------------
# Monitoramento (PRD §9)
# -----------------------------------------------------------------------------
# Sentry — DSN do projeto (Client Keys). Formato: https://...@....ingest.sentry.io/...
SENTRY_DSN=

# Sentry — token opcional do plugin/MCP (não substitui o DSN)
# SENTRY_AUTH_TOKEN=

# Logfire → logfire.pydantic.dev → projeto → token
LOGFIRE_TOKEN=


# -----------------------------------------------------------------------------
# Supabase — opcional (migrations CLI, SQL direto, Easypanel)
# -----------------------------------------------------------------------------
# Settings → Database → Connection string (Transaction pooler, porta 6543)
# SUPABASE_DATABASE_PASSWORD=
# SUPABASE_TRANSACTION_POOLER=postgresql://postgres.SEU_PROJETO:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
