# Backend FastAPI — copie para `backend/.env` ou use o `.env` na raiz do repositório.
# Documentação completa: ../.env.example

ENVIRONMENT=development
BACKEND_URL=http://localhost:8000
# Dashboard + origens fixas; sites do cliente vão em Configurações → Sites permitidos
ALLOWED_ORIGINS=http://localhost:3000
SECRET_KEY=change-me-use-openssl-rand-hex-32

SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Supabase → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

EVOLUTION_API_BASE_URL=https://sua-evolution-api.com
EVOLUTION_API_GLOBAL_KEY=

IPAPI_KEY=
# Client Keys (DSN) — Settings → Client Keys no projeto Sentry
SENTRY_DSN=
# Amostragem de performance (0.0–1.0). Reduza em produção se o volume for alto.
SENTRY_TRACES_SAMPLE_RATE=0.2
# Opcional: versão do deploy (release no Sentry)
# SENTRY_RELEASE=rastreamento-backend@0.1.0
LOGFIRE_TOKEN=
